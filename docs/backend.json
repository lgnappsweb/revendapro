
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Perfil do administrador do sistema.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "Dados dos clientes da revendedora.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Catálogo de produtos (Avon, Natura, etc).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "code": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Registro de vendas.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "total": { "type": "number" },
        "discount": { "type": "number" },
        "finalTotal": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientId", "clientName", "total", "finalTotal", "createdAt"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "Itens individuais de um pedido.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "subtotal": { "type": "number" }
      },
      "required": ["id", "orderId", "productId", "quantity", "unitPrice", "subtotal"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Dados de perfil do administrador."
    },
    "/admins/{adminId}": {
      "schema": "User",
      "description": "Coleção para controle de permissões admin."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Registro de clientes."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catálogo de produtos."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Registro de pedidos."
    },
    "/order_items/{itemId}": {
      "schema": "OrderItem",
      "description": "Itens detalhados das vendas."
    }
  }
}

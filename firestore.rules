
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Regra específica para o administrador baseada na existência na coleção admins
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if false; // Configurado manualmente ou via backend seguro
    }

    match /clients/{clientId} {
      allow read, write: if isAdmin();
    }

    match /products/{productId} {
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }

    match /order_items/{itemId} {
      allow read, write: if isAdmin();
    }
  }
}

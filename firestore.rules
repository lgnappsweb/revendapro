
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verifica se o usuário é um administrador (tem um registro na coleção admins)
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /admins/{adminId} {
      // Permite leitura se for o próprio usuário
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      // Permite escrita (criação) se for o próprio usuário se cadastrando
      allow write: if isAuthenticated() && request.auth.uid == adminId;
    }

    match /clients/{clientId} {
      allow read, write: if isAdmin();
    }

    match /products/{productId} {
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }

    match /order_items/{itemId} {
      allow read, write: if isAdmin();
    }
  }
}
